{% extends 'base.html.twig' %}

{% form_theme registrationForm 'bootstrap_5_layout.html.twig' %}

{% block title %}Inscription patient | MediRDV{% endblock %}

{% block body %}
    <main class="auth-shell container py-4 py-lg-5">
        <div class="row g-4 align-items-stretch">
            <div class="col-lg-5">
                <section class="auth-side h-100">
                    <a class="brand-lockup mb-4" href="{{ path('app_home') }}">
                        <span class="brand-mark">
                            <i class="bi bi-hospital"></i>
                        </span>
                        <span>
                            <span class="brand-title">MediRDV</span>
                            <span class="brand-subtitle">Inscription patient</span>
                        </span>
                    </a>
                    <span class="eyebrow mb-3">
                        <i class="bi bi-person-plus"></i>
                        Portail web et API alignes
                    </span>
                    <h1 class="hero-display fs-1 mb-3">Creer un compte patient.</h1>
                    <p class="hero-summary mb-0">
                        Cette inscription alimente la meme base utilisateurs que l authentification web et mobile,
                        avec un compte actif pret pour les prochains flux de rendez-vous.
                    </p>
                </section>
            </div>
            <div class="col-lg-7">
                <section class="auth-card">
                    {% include 'shared/_flashes.html.twig' %}

                    <div class="d-flex flex-column flex-md-row align-items-md-end justify-content-between gap-3 mb-4">
                        <div>
                            <p class="text-uppercase text-soft small fw-semibold mb-2">Inscription</p>
                            <h2 class="section-title mb-0">Creer un compte patient</h2>
                        </div>
                        <a class="soft-badge text-decoration-none" href="{{ path('app_login') }}">
                            <i class="bi bi-box-arrow-in-right"></i>
                            Deja inscrit ?
                        </a>
                    </div>

                    {{ form_start(registrationForm, { attr: { class: 'row g-3' } }) }}
                        <div class="col-md-6">
                            {{ form_row(registrationForm.firstName) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(registrationForm.lastName) }}
                        </div>
                        <div class="col-12">
                            {{ form_row(registrationForm.email) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(registrationForm.plainPassword.first) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(registrationForm.plainPassword.second) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(registrationForm.phone) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(registrationForm.dateOfBirth) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(registrationForm.gender) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(registrationForm.address) }}
                        </div>
                        <div class="col-12 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 pt-2">
                            <button type="submit" class="btn btn-primary btn-lg px-4">
                                Creer mon compte
                            </button>
                            <p class="text-soft mb-0">
                                Vous pourrez ensuite vous connecter sur le web et l API.
                            </p>
                        </div>
                    {{ form_end(registrationForm) }}
                </section>
            </div>
        </div>
    </main>
{% endblock %}
