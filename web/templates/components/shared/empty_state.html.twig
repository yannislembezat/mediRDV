<section class="empty-state">
    <span class="empty-state__icon" aria-hidden="true">
        <i class="bi {{ icon }}"></i>
    </span>
    <div>
        <h3 class="empty-state__title">{{ title }}</h3>
        <p class="empty-state__message">{{ message }}</p>
    </div>

    {% if actionLabel %}
        {% if actionHref %}
            <a class="btn btn-outline-primary" href="{{ actionHref }}">{{ actionLabel }}</a>
        {% else %}
            <span class="btn btn-outline-primary disabled">{{ actionLabel }}</span>
        {% endif %}
    {% endif %}
</section>
