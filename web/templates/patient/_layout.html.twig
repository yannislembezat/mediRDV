{% extends 'base.html.twig' %}

{% block body_class %}portal-body portal-body--patient{% endblock %}

{% block body %}
    {% set current_route = app.request.attributes.get('_route') ?? '' %}

    <div class="portal-frame container-fluid px-3 px-lg-4 py-3 py-lg-4">
        <header class="portal-topbar portal-topbar--patient d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center gap-4">
                <a class="brand-lockup" href="{{ path('patient_home') }}">
                    <span class="brand-mark"><i class="bi bi-hospital"></i></span>
                    <span class="d-none d-md-inline">
                        <span class="brand-title">MediRDV</span>
                        <span class="brand-subtitle">Parcours patient</span>
                    </span>
                </a>

                <nav class="portal-nav d-none d-lg-flex" aria-label="Navigation patient">
                    <a class="portal-nav-link {{ current_route in ['patient_home', 'patient_dashboard'] ? 'is-active' : '' }}" href="{{ path('patient_home') }}"><i class="bi bi-house-door me-2"></i>Accueil</a>
                    <a class="portal-nav-link {{ current_route in ['patient_search', 'patient_doctor', 'patient_booking'] ? 'is-active' : '' }}" href="{{ path('patient_search') }}"><i class="bi bi-search me-2"></i>Recherche</a>
                    <a class="portal-nav-link {{ current_route starts with 'patient_appointment' or current_route == 'patient_appointments' ? 'is-active' : '' }}" href="{{ path('patient_appointments') }}"><i class="bi bi-calendar2-check me-2"></i>Mes RDV</a>
                    <a class="portal-nav-link {{ current_route in ['patient_records', 'patient_record_show'] ? 'is-active' : '' }}" href="{{ path('patient_records') }}"><i class="bi bi-folder2-open me-2"></i>Dossier m.</a>
                </nav>
            </div>

            <div class="d-flex align-items-center gap-3">
                <div class="dropdown position-relative">
                    <button class="btn btn-light dropdown-toggle d-flex align-items-center gap-2 border-0 shadow-sm position-relative" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Notifications">
                        <i class="bi bi-bell fs-5 text-primary"></i>
                        {% if portal_unread_notifications is defined and portal_unread_notifications > 0 %}
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger notification-badge">
                                {{ portal_unread_notifications }}
                                <span class="visually-hidden">Notifications non lues</span>
                            </span>
                        {% endif %}
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 notification-dropdown" style="min-width: 350px; max-height: 500px; overflow-y: auto;">
                        {% if portal_notifications is defined and portal_notifications is not empty %}
                            {% for notification in portal_notifications|slice(0, 6) %}
                                <li class="px-0">
                                    <a href="#" class="notification-item dropdown-item py-3 px-3 {{ notification.isRead ? 'is-read' : '' }}" data-notification-id="{{ notification.id }}">
                                        <div class="d-flex gap-3">
                                            <div class="notification-icon flex-shrink-0">
                                                <i class="bi bi-info-circle-circle text-primary"></i>
                                            </div>
                                            <div class="notification-content flex-grow-1">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <h6 class="mb-1 fw-semibold notification-title">{{ notification.title }}</h6>
                                                    <small class="text-nowrap text-soft notification-date">{{ notification.createdAt|date('d/m') }}</small>
                                                </div>
                                                <p class="mb-1 text-muted small notification-message">{{ notification.message }}</p>
                                                <div class="d-flex align-items-center justify-content-between">
                                                    <span class="badge {{ notification.isRead ? 'bg-light text-muted' : 'bg-primary' }}">{{ notification.typeLabel }}</span>
                                                    {% if not notification.isRead %}
                                                        <button type="button" class="btn btn-sm btn-link py-0 px-0 text-decoration-none" data-action="notification#markRead">Marquer comme lue</button>
                                                    {% endif %}
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                </li>
                            {% endfor %}
                            {% if portal_notifications|length > 6 %}
                                <li class="px-3 py-2 text-center">
                                    <a href="{{ path('patient_records') }}" class="text-primary small text-decoration-none">
                                        Voir toutes les notifications
                                    </a>
                                </li>
                            {% endif %}
                        {% else %}
                            <li class="px-3 py-4 text-center">
                                <i class="bi bi-bell-slash text-muted fs-1 d-block mb-2"></i>
                                <p class="text-muted mb-0">Aucune notification</p>
                            </li>
                        {% endif %}
                    </ul>
                </div>
                <a class="btn btn-outline-primary btn-sm d-none d-sm-inline-flex" href="{{ path('patient_search') }}">
                    <i class="bi bi-calendar-plus me-1"></i> Nouveau RDV
                </a>

                <div class="dropdown">
                    <button class="btn btn-light dropdown-toggle d-flex align-items-center gap-2 border-0 shadow-sm" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person-circle fs-5 text-primary"></i>
                        <span class="d-none d-md-inline fw-medium">{{ app.user ? app.user.firstName : 'Mon compte' }}</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                        <li><h6 class="dropdown-header">{{ app.user ? app.user.fullName : 'Patient MediRDV' }}</h6></li>
                        <li><a class="dropdown-item py-2" href="{{ path('patient_profile') }}"><i class="bi bi-person me-2"></i>Mon profil</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            {% include 'shared/_logout_form.html.twig' with {
                                button_class: 'dropdown-item py-2 text-danger',
                                button_label: 'Se deconnecter',
                                button_icon: 'bi bi-box-arrow-right'
                            } only %}
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <div class="portal-shell-redesigned">
            <main class="portal-main-full w-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <p class="text-uppercase text-soft small fw-semibold mb-1">{% block portal_kicker %}Espace patient{% endblock %}</p>
                        <h1 class="h3 fw-bold text-dark mb-1">{% block portal_title %}{% endblock %}</h1>
                        <p class="text-secondary mb-0">{% block portal_summary %}{% endblock %}</p>
                    </div>
                    {% block portal_header_actions %}{% endblock %}
                </div>

                {% include 'shared/_flashes.html.twig' %}

                {% block portal_content %}{% endblock %}
            </main>


        </div>
    </div>
{% endblock %}
