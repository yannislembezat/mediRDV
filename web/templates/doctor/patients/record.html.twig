{% extends 'doctor/_layout.html.twig' %}

{% block title %}Dossier patient medecin | MediRDV{% endblock %}

{% block portal_title %}Dossier de {{ patient.fullName }}{% endblock %}
{% block portal_summary %}Vue consolidee du patient lie a votre activite: informations de contact, historique de rendez-vous sur votre planning et consultations completes du dossier medical.{% endblock %}

{% block portal_header_actions %}
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-secondary" href="{{ path('doctor_planning') }}">Retour au planning</a>
        {% set latest_appointment = doctorAppointments|first %}
        {% if latest_appointment %}
            <a class="btn btn-outline-primary" href="{{ path('doctor_appointment_show', { id: latest_appointment.id }) }}">Dernier rendez-vous</a>
        {% endif %}
    </div>
{% endblock %}

{% block portal_content %}
    <section class="portal-section">
        <div class="row g-4">
            <div class="col-xl-4">
                <div class="portal-panel h-100">
                    <p class="text-uppercase text-soft small fw-semibold mb-2">Identite patient</p>
                    <h2 class="section-title h4 mb-3">{{ patient.fullName }}</h2>

                    <dl class="profile-data-list">
                        <div>
                            <dt>Email</dt>
                            <dd>{{ patient.email }}</dd>
                        </div>
                        <div>
                            <dt>Telephone</dt>
                            <dd>{{ patient.phone ?: 'Non renseigne' }}</dd>
                        </div>
                        <div>
                            <dt>Date de naissance</dt>
                            <dd>{{ patient.dateOfBirth ? patient.dateOfBirth|date('d/m/Y') : 'Non renseignee' }}</dd>
                        </div>
                        <div>
                            <dt>Adresse</dt>
                            <dd>{{ patient.address ?: 'Non renseignee' }}</dd>
                        </div>
                    </dl>
                </div>
            </div>

            <div class="col-xl-8">
                <div class="portal-panel h-100">
                    <div class="portal-section__header">
                        <div>
                            <p class="text-uppercase text-soft small fw-semibold mb-2">Lien medecin / patient</p>
                            <h2 class="section-title h4 mb-0">Historique sur votre agenda</h2>
                        </div>
                    </div>

                    {% if doctorAppointments is not empty %}
                        <div class="record-list">
                            {% for appointment in doctorAppointments %}
                                <article class="record-card">
                                    <div class="record-card__header">
                                        <div>
                                            <strong>{{ appointment.dateTime|date('d/m/Y H:i') }}</strong>
                                            <p class="text-soft mb-0">{{ appointment.reason ?: 'Motif non renseigne' }}</p>
                                        </div>
                                        <div class="d-flex flex-wrap gap-2 align-items-center">
                                            {{ component('shared:status_badge', { status: appointment.status }) }}
                                            <a class="btn btn-outline-primary btn-sm" href="{{ path('doctor_appointment_show', { id: appointment.id }) }}">Ouvrir</a>
                                        </div>
                                    </div>
                                    {% if appointment.consultation and appointment.consultation.isCompleted %}
                                        <p class="record-card__excerpt mb-0">Consultation finalisee et archivable dans le dossier medical.</p>
                                    {% elseif appointment.consultation %}
                                        <p class="record-card__excerpt mb-0">Consultation ouverte mais encore modifiable.</p>
                                    {% else %}
                                        <p class="record-card__excerpt mb-0">Rendez-vous en attente de consultation.</p>
                                    {% endif %}
                                </article>
                            {% endfor %}
                        </div>
                    {% else %}
                        {{ component('shared:empty_state', {
                            icon: 'bi-calendar-x',
                            title: 'Aucun rendez-vous lie a ce patient',
                            message: 'Le dossier n expose aucun rendez-vous rattache a votre agenda.'
                        }) }}
                    {% endif %}
                </div>
            </div>
        </div>
    </section>

    <section class="portal-section">
        <div class="portal-section__header">
            <div>
                <p class="text-uppercase text-soft small fw-semibold mb-2">Dossier medical</p>
                <h2 class="section-title mb-0">Consultations completes du patient</h2>
            </div>
        </div>

        {% if patientRecords is not empty %}
            <div class="record-list">
                {% for record in patientRecords %}
                    <article class="record-card">
                        <div class="record-card__header">
                            <div>
                                <strong>{{ record.completedAt ? record.completedAt|date('d/m/Y H:i') : record.appointment.dateTime|date('d/m/Y H:i') }}</strong>
                                <p class="text-soft mb-0">{{ record.appointment.medecin.displayName }}</p>
                            </div>
                            <div class="d-flex flex-wrap gap-2 align-items-center">
                                {% if record.appointment.medecin.id == doctorProfile.id %}
                                    <span class="soft-badge is-accent">Votre consultation</span>
                                    <a class="btn btn-outline-primary btn-sm" href="{{ path('doctor_consultation_show', { id: record.id }) }}">Voir</a>
                                {% else %}
                                    <span class="soft-badge">Autre praticien</span>
                                {% endif %}
                            </div>
                        </div>

                        <div class="record-list">
                            <article class="record-card record-card--compact">
                                <strong>Diagnostic</strong>
                                <p class="mb-0 text-soft">{{ record.diagnosis ?: 'Aucun diagnostic detaille.' }}</p>
                            </article>
                            <article class="record-card record-card--compact">
                                <strong>Notes</strong>
                                <p class="mb-0 text-soft">{{ record.notes ?: 'Aucune note complementaire.' }}</p>
                            </article>
                        </div>

                        {% if record.prescription %}
                            <div class="prescription-list">
                                {% for item in record.prescription.items %}
                                    <article class="prescription-item">
                                        <div class="prescription-item__header">
                                            <div>
                                                <h3 class="h6 mb-1">{{ item.medication ? item.medication.name : (item.customName ?: 'Medicament') }}</h3>
                                                <p class="text-soft mb-0">{{ item.dosage }}</p>
                                            </div>
                                            {% if item.duration %}
                                                <span class="soft-badge">{{ item.duration }}</span>
                                            {% endif %}
                                        </div>
                                        <div class="prescription-item__meta">
                                            <span><strong>Frequence :</strong> {{ item.frequency ?: 'Selon besoin' }}</span>
                                            <span><strong>Instructions :</strong> {{ item.instructions ?: 'Aucune instruction detaillee.' }}</span>
                                        </div>
                                    </article>
                                {% endfor %}
                            </div>
                        {% else %}
                            <p class="text-soft mb-0">Aucune ordonnance associee a cette consultation.</p>
                        {% endif %}
                    </article>
                {% endfor %}
            </div>
        {% else %}
            {{ component('shared:empty_state', {
                icon: 'bi-journal-medical',
                title: 'Aucun dossier medical disponible',
                message: 'Le patient ne possede pas encore de consultation finalisee visible dans le dossier.'
            }) }}
        {% endif %}
    </section>
{% endblock %}
