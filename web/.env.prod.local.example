APP_ENV=prod
APP_SECRET=change-this-production-secret
DEFAULT_URI=https://medirdv.fr
DATABASE_URL="mysql://medirdv:change-me@db:3306/medirdv?serverVersion=8.0.32&charset=utf8mb4"
MESSENGER_TRANSPORT_DSN=sync://
CORS_ALLOW_ORIGIN='^https://(app\.)?medirdv\.fr$'
APP_TRUSTED_HOSTS='^(.+\.)?medirdv\.fr$'
APP_TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change-this-production-jwt-passphrase
